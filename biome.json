{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "html": {
    "formatter": {
      "enabled": true
    },
    "experimentalFullSupportEnabled": true
  },
  "files": {
    "includes": ["**", "!dist", "!coverage", "!node_modules", "!docs", "!bench"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "suspicious": {
        "noExplicitAny": "off",
        "noAssignInExpressions": "off"
      },
      "complexity": {
        "noUselessLoneBlockStatements": "off",
        "useOptionalChain": "off",
        "noCommaOperator": "off"
      }
    }
  }
}
